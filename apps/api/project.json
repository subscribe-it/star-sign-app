{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "build": {
      "command": "npm run build",
      "options": {
        "cwd": "apps/api"
      }
    },
    "serve": {
      "command": "npm run dev",
      "options": {
        "cwd": "apps/api"
      }
    },
    "strapi": {
      "command": "npm run strapi",
      "options": {
        "cwd": "apps/api"
      }
    },
    "seed-dev": {
      "command": "npm run seed:dev",
      "options": {
        "cwd": "apps/api"
      }
    },
    "premium-content-audit": {
      "command": "npm run premium-content-audit",
      "options": {
        "cwd": "apps/api"
      }
    },
    "premium-content-backfill": {
      "command": "npm run premium-content-backfill",
      "options": {
        "cwd": "apps/api"
      }
    },
    "aico-contract-audit": {
      "command": "npm run aico-contract-audit",
      "options": {
        "cwd": "apps/api"
      }
    },
    "aico-image-gen-smoke": {
      "command": "npm run aico-image-gen-smoke",
      "options": {
        "cwd": "apps/api"
      }
    },
    "test": {
      "command": "npx vitest run --config vitest.config.ts",
      "options": {
        "cwd": "apps/api"
      }
    }
  }
}
