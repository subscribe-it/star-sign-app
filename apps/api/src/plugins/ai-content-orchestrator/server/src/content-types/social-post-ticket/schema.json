{
  "kind": "collectionType",
  "collectionName": "aico_social_post_tickets",
  "info": {
    "singularName": "social-post-ticket",
    "pluralName": "social-post-tickets",
    "displayName": "AICO Social Post Ticket"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "platform": {
      "type": "enumeration",
      "enum": ["facebook", "instagram", "twitter", "tiktok", "youtube_shorts"],
      "required": true
    },
    "content_format": {
      "type": "enumeration",
      "enum": ["image", "video", "link", "story"],
      "default": "link"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "scheduled", "published", "failed", "canceled"],
      "default": "pending"
    },
    "caption": { "type": "text", "required": true },
    "media_url": { "type": "string" },
    "target_url": { "type": "string" },
    "scheduled_at": { "type": "datetime", "required": true },
    "published_on": { "type": "datetime" },
    "last_error": { "type": "text" },
    "attempt_count": { "type": "integer", "default": 0 },
    "next_attempt_at": { "type": "datetime" },
    "provider_post_id": { "type": "string" },
    "blocked_reason": { "type": "string" },
    "idempotency_key": { "type": "string", "unique": true },
    "provider_payload": { "type": "json", "private": true },
    "utm_campaign": { "type": "string" },
    "workflow": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.workflow"
    },
    "video_asset": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.video-asset"
    },
    "experiment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.growth-experiment"
    },
    "source_run": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.run-log"
    },
    "related_content_uid": { "type": "string" },
    "related_content_id": { "type": "integer" }
  }
}
