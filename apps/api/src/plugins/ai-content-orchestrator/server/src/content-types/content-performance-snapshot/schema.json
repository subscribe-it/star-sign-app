{
  "kind": "collectionType",
  "collectionName": "aico_content_performance_snapshots",
  "info": {
    "singularName": "content-performance-snapshot",
    "pluralName": "content-performance-snapshots",
    "displayName": "AICO Content Performance Snapshot"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "unique_key": { "type": "string", "required": true, "unique": true },
    "snapshot_day": { "type": "date", "required": true },
    "content_uid": { "type": "string", "required": true },
    "content_entry_id": { "type": "integer", "required": true },
    "content_slug": { "type": "string" },
    "content_title": { "type": "string" },
    "views": { "type": "integer", "default": 0 },
    "premium_events": { "type": "integer", "default": 0 },
    "cta_clicks": { "type": "integer", "default": 0 },
    "checkout_events": { "type": "integer", "default": 0 },
    "social_published": { "type": "integer", "default": 0 },
    "social_failed": { "type": "integer", "default": 0 },
    "organic_clicks": { "type": "integer", "default": 0 },
    "social_engagements": { "type": "integer", "default": 0 },
    "ad_spend_pln": { "type": "decimal", "default": 0 },
    "ad_clicks": { "type": "integer", "default": 0 },
    "ad_conversions": { "type": "integer", "default": 0 },
    "revenue_or_value": { "type": "decimal", "default": 0 },
    "freshness_days": { "type": "integer", "default": 0 },
    "score": { "type": "float", "default": 0 },
    "recommendations": { "type": "json" },
    "metadata": { "type": "json" },
    "workflow": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.workflow"
    }
  }
}
