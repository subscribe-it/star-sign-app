  "license": "MIT",
  "scripts": {
    "start": "nx run-many -t serve",
    "client": "nx serve frontend",
    "api": "nx serve api",
    "build": "nx run-many -t build",
    "ops:predeploy:local": "sh ops/predeploy-check.sh",
    "ops:predeploy:staging": "COMPOSE_FILE=ops/portainer/star-sign-production-stack.yml COMPOSE_ENV_FILE=.env PREDEPLOY_SCOPE=staging RUN_ENV_GUARD=true RUN_FRONTEND_FULL=true RUN_E2E=true RUN_DOMAIN_AUDITS=true RUN_AICO_POST_SEED_PREFLIGHT=true RUN_SECURITY_HEADERS=true sh ops/predeploy-check.sh",
    "ops:env": "sh ops/production-env-check.sh",
    "ops:headers": "sh ops/security-headers-check.sh",
    "ops:smoke": "sh ops/smoke.sh",
    "ops:load:soft": "artillery run ops/load/soft-launch.yml",
    "ops:sourcemaps:upload": "sentry-cli sourcemaps inject dist/frontend/browser && sentry-cli --url \"$SENTRY_URL\" sourcemaps --org \"${SENTRY_ORG:-star-sign}\" --project \"${SENTRY_PROJECT:-frontend}\" upload dist/frontend/browser"
  },
  "private": true,
