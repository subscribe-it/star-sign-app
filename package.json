    "@nx/vite": "22.7.0",
    "@nx/vitest": "22.7.0",
    "@nx/web": "22.7.0",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "21.2.13",
    "@sentry/cli": "^3.4.1",
