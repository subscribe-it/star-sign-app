# Star Sign production template for Docker Compose on a VPS.
# Copy to .env on the server and fill real values there. Do not commit real secrets.

NODE_ENV=production

# Public URLs
PRODUCTION_DOMAIN=star-sign.pl
FRONTEND_URL=https://star-sign.pl
API_PUBLIC_URL=https://api.star-sign.pl
SERVER_URL=https://api.star-sign.pl
API_URL=http://api:1337/api
FRONTEND_DOMAIN=star-sign.pl
API_DOMAIN=api.star-sign.pl
BUGSINK_DOMAIN=bugsink.star-sign.pl
ACME_EMAIL=admin@star-sign.pl
CORS_ORIGIN=https://star-sign.pl
UPLOAD_ASSET_CSP_ORIGINS=https://cdn.star-sign.pl

# Portainer / GHCR
GHCR_OWNER=subscribe-it
STAR_SIGN_IMAGE_TAG=main

# Feature flags
SHOP_ENABLED=false
FRONTEND_SHOP_ENABLED=false
PREMIUM_MODE=open
TURNSTILE_ENABLED=true
TURNSTILE_SITE_KEY=replace_me
TURNSTILE_SECRET_KEY=replace_me
TURNSTILE_FAIL_OPEN=false
GA4_MEASUREMENT_ID=replace_me
GTM_CONTAINER_ID=replace_me

# Strapi core secrets - generate unique random values for production
APP_KEYS=replace_me_1,replace_me_2,replace_me_3,replace_me_4
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me
ENCRYPTION_KEY=replace_me_32_chars_minimum

# Database
POSTGRES_DB=star_sign
POSTGRES_USER=star_sign
POSTGRES_PASSWORD=replace_me
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=star_sign
DATABASE_USERNAME=star_sign
DATABASE_PASSWORD=replace_me
DATABASE_SSL=false

# Cloudflare R2 / S3 upload provider
R2_UPLOAD_ENABLED=true
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_S3_ENDPOINT=https://replace_me.r2.cloudflarestorage.com
R2_BUCKET=star-sign
R2_REGION=auto
R2_FORCE_PATH_STYLE=true
R2_PUBLIC_BASE_URL=https://cdn.star-sign.pl
R2_ROOT_PATH=production

# Brevo newsletter and SMTP
BREVO_API_KEY=replace_me
BREVO_LIST_ID=1
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=replace_me
BREVO_SMTP_PASSWORD=replace_me
BREVO_FROM_EMAIL=Star Sign <noreply@star-sign.pl>
BREVO_REPLY_TO=kontakt@star-sign.pl
NEWSLETTER_DOUBLE_OPT_IN=true
BREVO_WEBHOOK_SECRET=replace_me

# Local testing (Mailpit) - defaults for development
# Set these in your .env to use Mailpit instead of Brevo:
# BREVO_SMTP_HOST=mailpit
# BREVO_SMTP_PORT=1025
# BREVO_SMTP_SECURE=false
# BREVO_SMTP_USER=
# BREVO_SMTP_PASSWORD=

# AICO / OpenRouter
AICO_OPENROUTER_TOKEN=replace_me
AICO_OPENROUTER_MODEL=openai/gpt-4.1-mini
AICO_ENABLE_WORKFLOWS=true
AICO_ALLOW_MISSING_TOKEN=false
AICO_BACKUP_ENABLED=true
AICO_AUDIT_TRAIL_STRICT=false
AICO_AUDIT_IP_HASH_SALT=
AICO_RUNTIME_LOCKS_DISABLED=false
AICO_SOCIAL_CONTENT_SAFETY_DISABLED=false
AICO_STRICT_AUDIT_REQUIRED=false
AICO_PROVIDER_READINESS_MAX_AGE_HOURS=24
AICO_CONTROLLED_LIVE_ENABLED=false
AICO_ADMIN_RUN_NOW_ENABLED=false
# Tryby ads: disabled -> sandbox -> controlled -> live.
# live = realne mutacje Meta/Google Ads (kampanie tworzone ZAWSZE jako PAUSED; aktywacja to osobny krok).
# live wymaga: AICO_CONTROLLED_LIVE_ENABLED=true, kompletu credentiali meta_ads/google_ads,
# swiezego provider-status ready (controlled smoke + probe) oraz zgody autonomy-policy i rezerwacji ledgera.
AICO_ADS_PROVIDER_MODE=disabled
# Timeout HTTP dla wywolan providerow ads (ms, domyslnie 15000).
AICO_ADS_PROVIDER_TIMEOUT_MS=
AICO_ADS_TARGET_URL_PREFLIGHT_REQUIRED=false
AICO_VIDEO_PROVIDER_MODE=disabled
AICO_VIDEO_GEN_TOKEN=
AICO_VIDEO_GEN_MODEL=
AICO_VIDEO_GEN_CANCEL_AFTER=15m
AICO_VIDEO_GEN_INPUT_JSON=
AICO_FULL_AUTONOMY_REQUIRED=false
AICO_AUTO_PUBLISH_ENABLED=true
AICO_IMAGE_GEN_TOKEN=
AICO_IMAGE_GEN_MODEL=openai/gpt-image-2
AICO_MEDIA_GEN_REQUIRED=false
AICO_PUBLIC_FRONTEND_URL=https://star-sign.pl
AICO_SOCIAL_DEFAULT_IMAGE_URL=https://star-sign.pl/assets/og-default.png
AICO_SOCIAL_PUBLISH_REQUIRED=false
AICO_SOCIAL_CONNECTION_PREFLIGHT=false
AICO_STRATEGY_AUTOPILOT_ENABLED=false
AICO_STRATEGY_AUTO_APPROVE_PLAN=false
AICO_STRATEGY_MIN_TOPIC_BACKLOG=3
AICO_STRATEGY_MAX_PLAN_ITEMS_PER_TICK=2
# Autonomiczna petla optymalizacji (insighty z performance/GA4/run-logow).
# Puste = domyslnie wlaczone, gdy AICO_ENABLE_WORKFLOWS=true; ustaw false aby wylaczyc.
AICO_INSIGHTS_ENABLED=
AICO_SOCIAL_CHANNELS=facebook,instagram,twitter
AICO_FACEBOOK_PAGE_ID=
AICO_FACEBOOK_ACCESS_TOKEN=
AICO_INSTAGRAM_USER_ID=
AICO_INSTAGRAM_ACCESS_TOKEN=
AICO_X_API_KEY=
AICO_X_API_SECRET=
AICO_X_ACCESS_TOKEN=
AICO_X_ACCESS_TOKEN_SECRET=
AICO_TIKTOK_ACCESS_TOKEN=
AICO_YOUTUBE_CLIENT_ID=
AICO_YOUTUBE_CLIENT_SECRET=
AICO_YOUTUBE_REFRESH_TOKEN=
AICO_META_ADS_ACCESS_TOKEN=
AICO_META_AD_ACCOUNT_ID=
# Provider API versions. Must be reviewed against provider deprecation schedules.
# Override when Meta/Google sunset a version (no code change needed).
AICO_META_GRAPH_API_VERSION=v21.0
AICO_GOOGLE_ADS_API_VERSION=v18
AICO_GOOGLE_ADS_DEVELOPER_TOKEN=
AICO_GOOGLE_ADS_CLIENT_ID=
AICO_GOOGLE_ADS_CLIENT_SECRET=
AICO_GOOGLE_ADS_REFRESH_TOKEN=
AICO_GOOGLE_ADS_CUSTOMER_ID=
# Set only when operating through a Google Ads MCC (manager) account.
AICO_GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GA4_PROPERTY_ID=
AICO_GA4_ACCESS_TOKEN=
GA4_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Plugins / observability
SENTRY_DSN=
FRONTEND_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_REQUIRED=false
SENTRY_TRACES_SAMPLE_RATE=0
STRAPI_DOCUMENTATION_ENABLED=false
STRAPI_SEO_PLUGIN_ENABLED=true

# Local Bugsink error tracker
BUGSINK_REQUIRED=false
BUGSINK_BASE_URL=https://bugsink.star-sign.pl
BUGSINK_SECRET_KEY=replace_me_50_chars_minimum
BUGSINK_CREATE_SUPERUSER=admin@example.com:replace_me
BUGSINK_POSTGRES_PASSWORD=replace_me
BUGSINK_ALERT_WEBHOOK_URL=
BUGSINK_SITE_TITLE=Star Sign Bugsink
BUGSINK_SINGLE_USER=true
BUGSINK_USER_REGISTRATION=CB_NOBODY

# Operations
OPS_ALERT_WEBHOOK_URL=
BACKUP_RETENTION_DAYS=14

# Security and limits
SECURITY_HSTS_ENABLED=true
REDIS_PASSWORD=replace_me
REDIS_URL=redis://:replace_me@redis:6379
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://:replace_me@redis:6379
RATE_LIMIT_KEY_PREFIX=star-sign:rate-limit:
RATE_LIMIT_PATHS=/api/auth/local,/api/auth/local/register,/api/contact,/api/newsletter,/api/checkout/session,/api/account/subscription
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=80
RATE_LIMIT_FAIL_OPEN=false
RATE_LIMIT_TRUST_PROXY=true
HTTP_CACHE_ENABLED=true
HTTP_CACHE_REDIS_URL=redis://:replace_me@redis:6379
HTTP_CACHE_KEY_PREFIX=star-sign:http-cache:
HTTP_CACHE_ARTICLES_TTL_SECONDS=300
HTTP_CACHE_ARTICLES_STALE_SECONDS=86400
HTTP_CACHE_HOROSCOPES_TTL_SECONDS=900
HTTP_CACHE_HOROSCOPES_STALE_SECONDS=3600
HTTP_CACHE_ZODIAC_SIGNS_TTL_SECONDS=86400
HTTP_CACHE_ZODIAC_SIGNS_STALE_SECONDS=604800
BODY_JSON_LIMIT=1mb
BODY_FORM_LIMIT=1mb
BODY_TEXT_LIMIT=1mb
UPLOAD_MAX_FILE_SIZE=10485760

# Seed guard
ALLOW_PRODUCTION_SEED=false

# Stripe / Premium subscriptions
STRIPE_REQUIRED=false
STRIPE_SECRET_KEY=replace_me_stripe_live_secret_key
STRIPE_WEBHOOK_SECRET=replace_me_stripe_webhook_secret
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_replace_me
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_replace_me
